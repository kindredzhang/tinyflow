# TinyFlow Configuration Example
# Copy this file to .env and update with your values

# ===========================================
# LLM Configuration
# ===========================================
LLM_API_KEY=""  # Your LLM API key
LLM_PROVIDER="openai"  # Options: openai, anthropic, gemini
LLM_MODEL="gpt-4o"  # Model name
LLM_BASE_URL=""  # Optional: Custom API base URL

# ===========================================
# Embedding Configuration
# ===========================================
EMBEDDING_PROVIDER="openai"  # Options: openai, local, sentence-transformers

# For OpenAI Embedding
EMBEDDING_MODEL="text-embedding-3-small"  # Options: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
EMBEDDING_BASE_URL=""  # Optional: Custom API base URL
EMBEDDING_API_KEY=""  # Optional: If different from LLM_API_KEY

# For Local Embedding (sentence-transformers)
EMBEDDING_MODEL_PATH="sentence-transformers/all-MiniLM-L6-v2"  # Model path or name
EMBEDDING_MODEL_DEVICE="auto"  # Options: auto, cpu, cuda, mps

# ===========================================
# Vector Database Configuration
# ===========================================
VECTOR_DB_PROVIDER="chroma"  # Options: chroma, qdrant, milvus, pinecone
VECTOR_DB_URL=""  # Cloud vector database URL
VECTOR_DB_API_KEY=""  # Cloud vector database API key
VECTOR_DB_PATH=""  # Local vector database storage path
VECTOR_DB_COLLECTION="conversations"  # Collection name

# ===========================================
# Search Configuration
# ===========================================
TAVILY_API_KEY=""  # Tavily search API key (optional)
